generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────
enum AccountType {
  CHECKING
  CREDIT
  CASH
}

enum TransactionDirection {
  DEBIT
  CREDIT
}

enum LedgerSource {
  BANK_IMPORT
  INVOICE
  MANUAL
}

enum LedgerStatus {
  PENDING
  CATEGORIZED
  MATCHED
}

enum MatchStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum ImportStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum InvoiceDirection {
  RECEIVED
  ISSUED
}

enum InvoiceFormat {
  ELECTRONIC
  PAPER
  RECEIPT
  CLOUD
  UNIFORM
}

enum TaxType {
  TAXABLE
  ZERO_RATE
  EXEMPT
}

enum AppMode {
  PERSONAL
  BUSINESS
}

enum InvoiceSource {
  MOF_CARRIER   // 財政部手機條碼載具同步
  MANUAL        // 手動新增
}

// ── Auth User ──────────────────────────────────────────
model AppUser {
  id               String              @id @default(cuid())
  email            String              @unique
  password         String
  name             String
  companyName      String?
  taxId            String?
  phone            String?
  mode             AppMode             @default(PERSONAL)
  invoiceQuota     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  businessInvoices BusinessInvoice[]
  categories       Category[]
  invoiceRecords   InvoiceRecord[]
  ledgerTransactions LedgerTransaction[]
  carrierBinding   CarrierBinding?

  @@index([email])
}

// ── Personal: Accounts ─────────────────────────────────
model Account {
  id           String          @id @default(cuid())
  userId       String
  name         String
  bankName     String
  accountType  AccountType     @default(CHECKING)
  currency     String          @default("TWD")
  createdAt    DateTime        @default(now())
  imports      BankImport[]
  transactions BankTransaction[]

  @@index([userId])
}

model BankImport {
  id           String          @id @default(cuid())
  accountId    String
  account      Account         @relation(fields: [accountId], references: [id])
  filename     String
  status       ImportStatus    @default(QUEUED)
  rowCount     Int             @default(0)
  importedAt   DateTime        @default(now())
  transactions BankTransaction[]

  @@index([accountId])
}

model BankTransaction {
  id         String               @id @default(cuid())
  importId   String
  import     BankImport           @relation(fields: [importId], references: [id])
  accountId  String
  account    Account              @relation(fields: [accountId], references: [id])
  txDate     DateTime
  merchant   String
  amount     Decimal              @db.Decimal(12, 2)
  direction  TransactionDirection
  memo       String?
  dedupeHash String               @unique
  ledger     LedgerTransaction?
  matchItems TransactionMatchItem[]

  @@index([accountId])
  @@index([txDate])
}

model InvoiceRecord {
  id          String        @id @default(cuid())
  userId      String?
  user        AppUser?      @relation(fields: [userId], references: [id])
  invoiceNo   String        @unique          // 財政部發票號碼（全球唯一）
  invoiceDate DateTime
  sellerName  String
  sellerTaxId String?
  amount      Decimal       @db.Decimal(12, 2)
  taxAmount   Decimal       @db.Decimal(12, 2) @default(0)
  carrier     String?                        // 手機條碼（/XXXXXXX）
  source      InvoiceSource @default(MANUAL) // 資料來源（防止 mock 混入）
  rawData     Json?
  syncedAt    DateTime      @default(now())
  ledger      LedgerTransaction?
  matchItems  TransactionMatchItem[]

  @@index([invoiceDate])
  @@index([userId])
  @@index([source])
}

// ── 手機條碼載具綁定（每 user 一筆，cardEncrypt 不儲存）─────
model CarrierBinding {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          AppUser   @relation(fields: [userId], references: [id])
  cardNo        String                         // /XXXXXXX 手機條碼
  lastSyncedAt  DateTime?                      // 上次同步時間（rate limit 用）
  lastSyncMonth String?                        // 上次同步月份 YYYY-MM
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model Category {
  id           String             @id @default(cuid())
  userId       String?
  user         AppUser?           @relation(fields: [userId], references: [id])
  name         String
  icon         String?
  color        String?
  isSystem     Boolean            @default(false)
  transactions LedgerTransaction[]
  rules        CategoryRule[]

  @@unique([userId, name])
}

model LedgerTransaction {
  id          String               @id @default(cuid())
  userId      String?
  user        AppUser?             @relation(fields: [userId], references: [id])
  source      LedgerSource
  status      LedgerStatus         @default(PENDING)
  txDate      DateTime
  amount      Decimal              @db.Decimal(12, 2)
  direction   TransactionDirection
  description String
  categoryId  String?
  category    Category?            @relation(fields: [categoryId], references: [id])
  bankTxId    String?              @unique
  bankTx      BankTransaction?     @relation(fields: [bankTxId], references: [id])
  invoiceId   String?              @unique
  invoice     InvoiceRecord?       @relation(fields: [invoiceId], references: [id])
  createdAt   DateTime             @default(now())

  @@index([txDate])
  @@index([categoryId])
  @@index([userId])
}

model TransactionMatch {
  id        String               @id @default(cuid())
  confidence Float
  status    MatchStatus          @default(PENDING)
  createdAt DateTime             @default(now())
  items     TransactionMatchItem[]
}

model TransactionMatchItem {
  id        String           @id @default(cuid())
  matchId   String
  match     TransactionMatch @relation(fields: [matchId], references: [id])
  bankTxId  String?
  bankTx    BankTransaction? @relation(fields: [bankTxId], references: [id])
  invoiceId String?
  invoice   InvoiceRecord?   @relation(fields: [invoiceId], references: [id])
}

model CategoryRule {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  pattern    String
  priority   Int      @default(0)
  isRegex    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([categoryId])
}

// ── Business: Invoices ─────────────────────────────────
model BusinessInvoice {
  id                String           @id @default(cuid())
  userId            String
  user              AppUser          @relation(fields: [userId], references: [id])
  direction         InvoiceDirection
  format            InvoiceFormat    @default(ELECTRONIC)
  invoiceNo         String
  invoiceDate       DateTime
  counterpartyName  String
  counterpartyTaxId String?
  amount            Decimal          @db.Decimal(12, 2)
  taxAmount         Decimal          @db.Decimal(12, 2)
  untaxedAmount     Decimal          @db.Decimal(12, 2)
  taxType           TaxType          @default(TAXABLE)
  description       String?
  imageUrl          String?
  createdAt         DateTime         @default(now())

  @@unique([userId, invoiceNo])
  @@index([userId, direction])
  @@index([invoiceDate])
}
