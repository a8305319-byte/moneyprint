generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType { CHECKING CREDIT CASH }
enum TransactionDirection { DEBIT CREDIT }
enum LedgerSource { BANK_IMPORT INVOICE MANUAL }
enum LedgerStatus { PENDING CATEGORIZED MATCHED }
enum MatchStatus { PENDING CONFIRMED REJECTED }
enum ImportStatus { QUEUED PROCESSING DONE FAILED }

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  accounts  Account[]
  categories Category[]
}

model Account {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  name         String
  bankName     String
  accountType  AccountType @default(CHECKING)
  currency     String      @default("TWD")
  createdAt    DateTime    @default(now())
  imports      BankImport[]
  transactions BankTransaction[]
  @@index([userId])
}

model BankImport {
  id           String       @id @default(cuid())
  accountId    String
  account      Account      @relation(fields: [accountId], references: [id])
  filename     String
  status       ImportStatus @default(QUEUED)
  rowCount     Int          @default(0)
  importedAt   DateTime     @default(now())
  transactions BankTransaction[]
  @@index([accountId])
}

model BankTransaction {
  id          String               @id @default(cuid())
  importId    String
  import      BankImport           @relation(fields: [importId], references: [id])
  accountId   String
  account     Account              @relation(fields: [accountId], references: [id])
  txDate      DateTime
  merchant    String
  amount      Decimal              @db.Decimal(12,2)
  direction   TransactionDirection
  memo        String?
  dedupeHash  String               @unique
  ledger      LedgerTransaction?
  matchItems  TransactionMatchItem[]
  @@index([accountId])
  @@index([txDate])
}

model InvoiceRecord {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  invoiceDate DateTime
  sellerName  String
  sellerTaxId String?
  amount      Decimal  @db.Decimal(12,2)
  taxAmount   Decimal  @db.Decimal(12,2) @default(0)
  carrier     String?
  rawData     Json?
  syncedAt    DateTime @default(now())
  ledger      LedgerTransaction?
  matchItems  TransactionMatchItem[]
  @@index([invoiceDate])
}

model Category {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  name         String
  icon         String?
  color        String?
  isSystem     Boolean  @default(false)
  transactions LedgerTransaction[]
  rules        CategoryRule[]
  @@unique([userId, name])
}

model LedgerTransaction {
  id          String               @id @default(cuid())
  source      LedgerSource
  status      LedgerStatus         @default(PENDING)
  txDate      DateTime
  amount      Decimal              @db.Decimal(12,2)
  direction   TransactionDirection
  description String
  categoryId  String?
  category    Category?            @relation(fields: [categoryId], references: [id])
  bankTxId    String?              @unique
  bankTx      BankTransaction?     @relation(fields: [bankTxId], references: [id])
  invoiceId   String?              @unique
  invoice     InvoiceRecord?       @relation(fields: [invoiceId], references: [id])
  createdAt   DateTime             @default(now())
  @@index([txDate])
  @@index([categoryId])
}

model TransactionMatch {
  id         String               @id @default(cuid())
  confidence Float
  status     MatchStatus          @default(PENDING)
  createdAt  DateTime             @default(now())
  items      TransactionMatchItem[]
}

model TransactionMatchItem {
  id        String           @id @default(cuid())
  matchId   String
  match     TransactionMatch @relation(fields: [matchId], references: [id])
  bankTxId  String?
  bankTx    BankTransaction? @relation(fields: [bankTxId], references: [id])
  invoiceId String?
  invoice   InvoiceRecord?   @relation(fields: [invoiceId], references: [id])
}

model CategoryRule {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  pattern    String
  priority   Int      @default(0)
  isRegex    Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@index([categoryId])
}
